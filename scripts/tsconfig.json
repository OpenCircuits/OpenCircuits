{
  "compilerOptions": {
    "lib": ["es2021"],
    "allowJs": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2024",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "sourceMap": true,
    "inlineSourceMap": false,
    "inlineSources": true,
    "declaration": false,
    "erasableSyntaxOnly": true,
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}
