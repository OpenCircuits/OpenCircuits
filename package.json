{
  "private": true,
  "workspaces": [
    "src/projects/shared/api/*",
    "src/projects/shared/site",
    "src/projects/analog/api/*",
    "src/projects/analog/site",
    "src/projects/digital/api/*",
    "src/projects/digital/site",
    "src/other/pages/*"
  ],
  "type": "module",
  "scripts": {
    "start": "node ./scripts/start.ts",
    "start:server": "node ./scripts/start.ts src/server",
    "start:server:no_auth": "yarn start src/server --extraFlags='--no_auth'",
    "build": "node ./scripts/build.ts",
    "build:prod": "node ./scripts/build.ts --prod server digital",
    "test": "node ./scripts/test.ts",
    "coverage": "node ./scripts/test.ts --coverage",
    "build:ngspice": "node ./scripts/ngspice/build.ts",
    "test-e2e:digital": "npx playwright test --config ./playwright/config/digital.config.ts",
    "test-e2e:landing": "npx playwright test --config ./playwright/config/landing.config.ts",
    "test-e2e:ci": "npx playwright test --config ./playwright/config/ci.config.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "protoc": "protoc --plugin=./node_modules/.bin/protoc-gen-ts_proto.cmd --ts_proto_out=. ./src/projects/shared/site/src/proto/Circuit.proto",
    "protoc-digital": "protoc --plugin=./node_modules/.bin/protoc-gen-ts_proto.cmd --ts_proto_out=. ./src/projects/shared/site/src/proto/Circuit.proto ./src/projects/digital/site/src/proto/DigitalCircuit.proto"
  },
  "dependencies": {
    "benchmark": "^2.1.4"
  },
  "devDependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "@babel/core": "^7.27.7",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@playwright/test": "^1.53.1",
    "@pmmmwh/react-refresh-webpack-plugin": "0.5.7",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.2.1",
    "@types/benchmark": "^2.1.5",
    "@types/jest": "^29.5.1",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^18.7.16",
    "@types/prompts": "^2.0.14",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/react-redux": "^7.1.34",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "babel-loader": "^10.0.0",
    "babel-plugin-react-compiler": "^19.1.0-rc.2",
    "chalk": "^5.0.1",
    "copyfiles": "^2.4.1",
    "css-loader": "^6.7.1",
    "detect-port-alt": "^1.1.6",
    "dotenv": "^16.0.1",
    "dotenv-expand": "^8.0.3",
    "emscript-loader": "^1.0.6",
    "eslint": "^9.31.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-playwright": "^2.2.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "file-loader": "^6.2.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "@soda/friendly-errors-webpack-plugin": "^1.8.1",
    "globals": "^16.3.0",
    "html-webpack-plugin": "^5.5.0",
    "interpolate-html-plugin": "^4.0.0",
    "jest": "^29.5.0",
    "jest-canvas-mock": "^2.5.2",
    "jest-environment-jsdom": "^29.5.0",
    "jest-fail-on-console": "^3.3.1",
    "jest-watch-typeahead": "^2.2.2",
    "mini-css-extract-plugin": "^2.6.1",
    "open": "^8.4.0",
    "ora": "^6.1.2",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.22.1",
    "postcss": "^8.4.14",
    "postcss-loader": "^7.0.0",
    "postcss-preset-env": "^7.7.2",
    "prompts": "^2.4.2",
    "react-refresh": "0.14.0",
    "react-refresh-typescript": "^2.0.9",
    "sass": "^1.53.0",
    "sass-loader": "^13.0.2",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.2",
    "ts-morph": "^18.0.0",
    "ts-proto": "^2.7.0",
    "typescript": "^5.8.2",
    "url-loader": "^4.1.1",
    "webpack": "^5.73.0",
    "webpack-cli": "^4.10.0",
    "webpack-dev-server": "^4.9.3",
    "yargs": "^17.5.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": "^24"
  }
}
